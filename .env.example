# Copy to .env for local development (never commit .env).
# On Render: set the same variables in the service Environment (no .env file).
# Discord app setup: https://discord.com/developers/applications

DISCORD_TOKEN=
ALERT_CHANNEL_ID=

# Guild where per-worker monitor channels are created (server ID). The bot must be
# in this guild with Manage Channels (and Send Messages / Embed Links in those channels).
MONITOR_GUILD_ID=

# SQLite file for worker snapshot state and worker_id -> channel_id mapping.
# On Render, point to a persistent disk path if you need survives redeploys.
STATE_DB_PATH=data/state.db

# Optional: create worker channels under this category (category channel ID).
# MONITOR_CATEGORY_ID=

# Optional: instant slash-command sync in ONE server only.
TEST_GUILD_ID=

# Optional: restrict /testalert and prefer /setupchannels for this user ID.
BOT_OWNER_USER_ID=

# Optional: show "View commit on GitHub" in /testalert when commit SHA is known.
# Example: yourname/yourrepo
# GITHUB_REPO=

# AAA national gas worker (optional; defaults shown)
# Poll interval default when SQLite has no saved setting (seconds; clamped 60–86400).
# AAA_GAS_POLL_INTERVAL_SECONDS=300
# Page URL to scrape (default https://gasprices.aaa.com/)
# AAA_GAS_PAGE_URL=https://gasprices.aaa.com/
# Override User-Agent for HTTP fetches (defaults to a Chrome-on-Windows string).
# If you still get HTTP 403 from gasprices.aaa.com (e.g. on cloud hosts), paste your
# desktop browser's User-Agent here — the site often blocks datacenter IPs regardless.
# AAA_GAS_HTTP_USER_AGENT=
# Table parser: column header to treat as national average (default Regular unleaded).
# AAA_GAS_TABLE_GRADE=Regular

# Bonbast live rates worker (optional; defaults shown)
# Poll interval when SQLite has no saved setting (seconds; clamped 60–86400).
# BONBAST_POLL_INTERVAL_SECONDS=300
# Site origin (no trailing path; default https://bonbast.com)
# BONBAST_BASE_URL=https://bonbast.com
# BONBAST_HTTP_USER_AGENT=
# ISO-like currency code for /json keys (default usd → usd1/usd2 sell/buy)
# BONBAST_CURRENCY_CODE=usd