# Copy to .env for local development (never commit .env).
# On Render: set the same variables in the service Environment (no .env file).
# Discord app setup: https://discord.com/developers/applications

DISCORD_TOKEN=
ALERT_CHANNEL_ID=

# Optional: instant slash-command sync in ONE server only. Must match a server
# where this bot is invited with OAuth2 scope "applications.commands".
# If you get 403 / Missing Access on startup, remove this line or fix the invite.
TEST_GUILD_ID=

# Optional: restrict /testalert to one user ID (your Discord user ID).
BOT_OWNER_USER_ID=

# Optional: for later SQLite persistence on Render persistent disk.
# STATE_DB_PATH=/data/state.db
